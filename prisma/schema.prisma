generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerType {
  B2C // Bireysel
  B2B // Kurumsal
}

enum PestType {
  UCAN_HASERE // Sivrisinek, Karasinek, Arı
  YURIYEN_HASERE // Hamam Böceği, Kalorifer Böceği, vb.
  KEMIRGEN // Fare, Sıçan
  OZEL_MUDAHALE // Akrep, Yılan
  DIGER
}

model Lead {
  id            String       @id @default(uuid())
  customerType  CustomerType
  areaSizeSqM   Int?
  pestType      PestType
  serviceArea   String       // İlçe / Mahalle / Tesis tipi vb.
  fullName      String
  phoneNumber   String
  email         String?
  isUrgent      Boolean      @default(false)
  message       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}
